<Window x:Class="InputBridge.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InputBridge Controller" Height="610" Width="900" MinHeight="520" MinWidth="760">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Background="#F4F6F8" CornerRadius="8" Padding="14">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="InputBridge Controller" FontSize="22" FontWeight="SemiBold"/>
          <TextBlock x:Name="StatusText" Margin="0,5,0,0" Foreground="#456" TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Margin="4" Padding="10,5" Click="ApplyWindows_Click">Apply Windows</Button>
          <Button Margin="4" Padding="10,5" Click="ApplyMac_Click">Apply Mac</Button>
        </StackPanel>
      </Grid>
    </Border>

    <TabControl Grid.Row="1" Margin="0,14,0,14">
      <TabItem Header="Monitors">
        <Grid Margin="12">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <TextBlock Text="Choose the physical monitors that belong to the shared workspace. Input values use DDC/CI VCP 0x60." TextWrapping="Wrap"/>
          <DataGrid x:Name="MonitorGrid" Grid.Row="1" Margin="0,12,0,12" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False">
            <DataGrid.Columns>
              <DataGridCheckBoxColumn Header="Use" Binding="{Binding Enabled, Mode=TwoWay}" Width="55"/>
              <DataGridTextColumn Header="Monitor" Binding="{Binding Description}" IsReadOnly="True" Width="*"/>
              <DataGridTextColumn Header="Current" Binding="{Binding CurrentInputHex}" IsReadOnly="True" Width="85"/>
              <DataGridTextColumn Header="Windows input" Binding="{Binding WindowsInputHex, Mode=TwoWay}" Width="120"/>
              <DataGridTextColumn Header="Mac input" Binding="{Binding MacInputHex, Mode=TwoWay}" Width="100"/>
            </DataGrid.Columns>
          </DataGrid>
          <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Padding="10,5" Margin="0,0,8,0" Click="RefreshMonitors_Click">Refresh monitors</Button>
            <Button Padding="10,5" Click="SaveMonitors_Click">Save monitor setup</Button>
          </StackPanel>
        </Grid>
      </TabItem>
      <TabItem Header="Pairing">
        <Grid Margin="12">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <TextBlock Text="A Mac companion discovered on the local network requests pairing here. Approval creates a token without copying IP addresses or secrets." TextWrapping="Wrap"/>
          <DataGrid x:Name="PairingGrid" Grid.Row="1" Margin="0,12,0,12" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Mac" Binding="{Binding ClientName}" Width="*"/>
              <DataGridTextColumn Header="Requested" Binding="{Binding RequestedAtLocal}" Width="180"/>
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
          </DataGrid>
          <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Padding="10,5" Margin="0,0,8,0" Click="ApprovePairing_Click">Approve selected</Button>
            <Button Padding="10,5" Click="RejectPairing_Click">Reject selected</Button>
          </StackPanel>
        </Grid>
      </TabItem>
      <TabItem Header="About">
        <StackPanel Margin="16">
          <TextBlock FontSize="16" FontWeight="SemiBold" Text="InputBridge local controller"/>
          <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="The controller uses UDP multicast discovery on port 41716 and HTTP on port 41715 by default. Your installer should create Private-network firewall rules for both ports. Pairing tokens are never displayed in this UI."/>
        </StackPanel>
      </TabItem>
    </TabControl>

    <TextBlock x:Name="FooterText" Grid.Row="2" Foreground="#666" TextWrapping="Wrap"/>
  </Grid>
</Window>
